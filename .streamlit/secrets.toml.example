# 이 파일을 복사해 `.streamlit/secrets.toml` 로 만들고 값을 채우세요.
# `.streamlit/secrets.toml` 은 .gitignore로 제외되어 커밋되지 않습니다.
# 배포(Streamlit Community Cloud)에서는 앱 대시보드의 Settings → Secrets 칸에
# 아래와 동일한 형식으로 붙여넣습니다.

# Claude(챗봇)용 — https://console.anthropic.com 에서 발급 (필수)
ANTHROPIC_API_KEY = "sk-ant-..."

# 접근 비밀번호(설정 시 입장 게이트 활성화, 비우면 공개 모드)
APP_PASSWORD = "set-a-strong-password"

# Materials Project — 선택. data.py에 무료 기본 키가 내장돼 있어 설정 안 해도
# 동작합니다. 본인 키로 바꾸려면 아래 주석을 해제하세요.
# MP_API_KEY = "your-materials-project-api-key"
